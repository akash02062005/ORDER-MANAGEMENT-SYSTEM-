# ============================================================================
# OrderStream backend environment variables
# Copy this file to .env and fill in your values before running:
#   mvn spring-boot:run
# ============================================================================

# --- MongoDB ---
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/order_management

# --- JWT ---
JWT_SECRET=please-generate-a-long-random-string
JWT_EXPIRATION=86400000

# --- Email: Resend API (required for OTP and magic link emails) ---
# Get your free API key at https://resend.com/signup -> https://resend.com/api-keys
# Free tier: 100 emails/day, 3000/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=OrderStream <onboarding@resend.dev>

# --- OAuth2 removed — email-only authentication ---

# --- Razorpay ---
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=

# --- App ---
APP_FRONTEND_URL=http://localhost:5173
APP_MAGIC_LINK_SECRET=please-generate-a-long-random-string-too
