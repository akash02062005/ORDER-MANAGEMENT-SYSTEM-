# ============================================================================
# OrderStream backend environment variables
# Copy this file to .env and fill in your values before running:
#   mvn spring-boot:run
# ============================================================================

# --- MongoDB ---
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/order_management

# --- JWT ---
JWT_SECRET=please-generate-a-long-random-string
JWT_EXPIRATION=86400000

# --- Email (Brevo — preferred) ---
# 300 free emails/day. No domain verification required, but you must verify the SENDER address
# in Brevo dashboard: Senders, Domains & Dedicated IPs -> Senders -> Add a sender.
# Get key at https://app.brevo.com -> SMTP & API -> API keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=OrderStream <your-verified-sender@gmail.com>

# --- Email (Resend — fallback, only used if BREVO_API_KEY is unset) ---
# Free tier: 100 emails/day, but free plan only delivers to YOUR Resend account email
# unless you verify a custom domain at https://resend.com/domains
RESEND_API_KEY=
RESEND_FROM_EMAIL=OrderStream <onboarding@resend.dev>

# --- OAuth2 removed — email-only authentication ---

# --- Razorpay ---
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=

# --- App ---
APP_FRONTEND_URL=http://localhost:5173
APP_MAGIC_LINK_SECRET=please-generate-a-long-random-string-too
